# n8n Webhook URLs - replace with your actual n8n Cloud instance URLs
N8N_BASE_URL=https://your-instance.app.n8n.cloud

# Webhook paths (these match the workflow webhook nodes)
AGENT1_WEBHOOK_PATH=/webhook/security-scanner-start
AGENT2_WEBHOOK_PATH=/webhook/vuln-assessment-start
AGENT3_WEBHOOK_PATH=/webhook/compliance-check

# Webhook authentication key (configured in n8n HTTP Header Auth)
WEBHOOK_API_KEY=your-webhook-api-key-here

# Test timeout in milliseconds (workflows can take a while)
TEST_TIMEOUT_MS=120000

# Supabase scan-orchestrator edge function URL
# Format: https://<project-ref>.supabase.co/functions/v1/scan-orchestrator
SCAN_ORCHESTRATOR_URL=https://your-project.supabase.co/functions/v1/scan-orchestrator

# Supabase service-role key (needed to call edge functions)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
